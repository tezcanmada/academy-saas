generator client {
  provider = "prisma-client-js"
}
datasource db {
  provider = "postgresql"
}



enum Role {
  ADMIN
  EDUCATOR
  PRACTITIONER
  CLIENT
}

model User {
  id                        String   @id @default(uuid())
  email                     String   @unique
  fullName                  String
  phone                     String?
  role                      Role     @default(CLIENT)
  referredBy                String?  
  systemStorageConsent      Boolean  @default(false)
  fullFaceVisibleConsent    Boolean  @default(false)
  socialMediaSharingConsent Boolean  @default(false)
  isActive                  Boolean  @default(true)
  createdAt                 DateTime @default(now())
  updatedAt                 DateTime @updatedAt

  @@map("users")
}